                       nameSet[armName] = true table.insert(uniqueNames, armName)
                   end
               end
               ArmDropdown:Refresh(uniqueNames, true)
           end
       end)
   end,
})

GoldenTab:CreateToggle({
   Name = "Auto-Craft Selected Arm",
   CurrentValue = false,
   Callback = function(Value)
       _G.AutoGoldenSelectedArm = Value
       task.spawn(function()
           while _G.AutoGoldenSelectedArm do
               if selectedArmToGold ~= "None" then
                   pcall(function()
                       local ownedArms = ArmsService.RF.getOwned:InvokeServer(Player)
                       local uuids = {}
                       for uuid, armData in pairs(ownedArms) do
                           local aName = tostring(armData.ArmKey or armData.Key or armData.Id)
                           if tostring(armData.Tier or "Normal") == "Normal" and aName == selectedArmToGold then
                               table.insert(uuids, uuid)
                           end
                       end
                       while #uuids >= 5 do
                           local batch = {uuids[1], uuids[2], uuids[3], uuids[4], uuids[5]}
                           for i = 1, 5 do table.remove(uuids, 1) end
                           ArmsService.RF.goldify:InvokeServer(batch)
                           task.wait(0.3) 
                       end
                   end)
               end
               task.wait(3)
           end
       end)
   end,
})


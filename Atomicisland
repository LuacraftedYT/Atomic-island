local activeTreeLocations = treeDatabase["Palm Trees"]

task.spawn(function()
    if ChaosService.DamageBreakableSignal then
        ChaosService.DamageBreakableSignal:Connect(function(damageData)
            pcall(function()
                if currentTargetTreeID and type(damageData) == "table" then
                    for _, info in pairs(damageData) do

local Knit = require(ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Knit"))

-- Safe Service Retrieval
local function GetS(serviceName)
    local s = nil
    pcall(function() s = Knit.GetService(serviceName) end)
    return s
end

local ChaosService = GetS("ChaosBreakablesService")
local PetService = GetS("PetService")
local ArmsService = GetS("ArmsService")
local MerchantService = GetS("MerchantService")
local GraveService = GetS("GraveDiggerService")


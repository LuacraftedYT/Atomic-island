local platform = workspace:FindFirstChild("LuacraftedPlatform")
if not platform then
    platform = Instance.new("Part")
    platform.Name = "LuacraftedPlatform"
    platform.Size = Vector3.new(5, 1, 5)
    platform.Anchored = true
    platform.Transparency = 1
    platform.CanCollide = true
    platform.Parent = workspace
end

FarmTab:CreateDropdown({
    Name = "Select Farming Route",
    Options = {"Palm Trees", "Chaos Trees", "Infested Trees", "Toxic Trees"},
    CurrentOption = {"Palm Trees"},
    Callback = function(Option) activeTreeLocations = treeDatabase[Option[1]] end
})

FarmTab:CreateToggle({
   Name = "Start Hardcoded Coordinate Farm",
   CurrentValue = false,
   Callback = function(Value)
       autoFarmActive = Value
       local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
       if not Value then if root then root.Anchored = false end platform.Position = Vector3.new(0, -10000, 0) currentTargetTreeID = nil end
       if autoFarmActive then
           task.spawn(function()
               while autoFarmActive do
                   for _, targetCoord in ipairs(activeTreeLocations) do
                       if not autoFarmActive then break end
                       local currentTree = nil
                       for _, tree in ipairs(workspace.GameObjects.ChaosBreakables:GetDescendants()) do
                           if tree:IsA("Model") and tree:GetAttribute("Destroyed") ~= true then
                               if (tree:GetPivot().Position - targetCoord).Magnitude < 15 then currentTree = tree break end
                           end
                       end
                       if currentTree then
                           root = Player.Character:FindFirstChild("HumanoidRootPart")
                           if root then
                               currentTargetTreeID = currentTree:GetAttribute("ID")
                               local safePos = targetCoord + Vector3.new(2, 3.5, 2)
                               platform.Position = safePos - Vector3.new(0, 3, 0)
                               local uprightLookTarget = Vector3.new(targetCoord.X, safePos.Y, targetCoord.Z)
                               root.CFrame = CFrame.lookAt(safePos, uprightLookTarget)
                               root.Anchored = true task.wait(0.05) root.Anchored = false task.wait(0.05) root.Anchored = true
                               lastDamageTime = os.clock() 
                               local attackStartTime = os.clock()
                               while autoFarmActive and currentTree and currentTree.Parent and currentTree:GetAttribute("Destroyed") ~= true do
                                   pcall(function() ChaosService:Clicked() end)
                                   if os.clock() - lastDamageTime > 6 then break end
                                   if os.clock() - attackStartTime > 120 then break end
                                   task.wait(0.05) 
                               end
                               currentTargetTreeID = nil
                               if root then root.Anchored = false end
                           end
                       end
                   end
                   task.wait(0.5) 
               end
           end)
       end
   end,
})

--- [[ MODULE 4: GOLDEN TAB (HEAVILY UPDATED) ]] ---
local selectedPetToGold = "None"
local selectedArmToGold = "None"
local specialTargets = {"MeltdownToad_Baby_Normal", "MoltenIsland", "TornadoIsland", "BuffCoral", "SandstoneMuscle"}

local PetDropdown = GoldenTab:CreateDropdown({
    Name = "Target Pet",
    Options = {"None"},
    CurrentOption = {"None"},
    Callback = function(Option) selectedPetToGold = Option[1] end
})

GoldenTab:CreateButton({
   Name = "🔄 Refresh Pet Inventory",
   Callback = function()
       pcall(function()
           local ownedPets = PetService.RF.getOwned:InvokeServer()
           if type(ownedPets) == "table" then
               local uniqueNames = {"None"}
               for _, s in ipairs(specialTargets) do table.insert(uniqueNames, s) end
               local nameSet = {}
               for _, petData in pairs(ownedPets) do
                   local petName = tostring(petData.Key or petData.Id or petData.TemplateId or "Unknown")
                   if petName ~= "Unknown" and not nameSet[petName] then
                       nameSet[petName] = true table.insert(uniqueNames, petName)
                   end
               end
               PetDropdown:Refresh(uniqueNames, true)
           end
       end)
   end,
})

GoldenTab:CreateToggle({
   Name = "Auto-Craft Selected Pet",
   CurrentValue = false,
   Callback = function(Value)
       _G.AutoGoldenSelectedPet = Value
       task.spawn(function()
           while _G.AutoGoldenSelectedPet do
               if selectedPetToGold ~= "None" then
                   pcall(function()
                       local ownedPets = PetService.RF.getOwned:InvokeServer()
                       local uuids = {}
                       for uuid, petData in pairs(ownedPets) do
                           local pName = tostring(petData.Key or petData.Id or petData.TemplateId)
                           if tostring(petData.Tier) == "Normal" and pName == selectedPetToGold then
                               table.insert(uuids, uuid)
                           end
                       end
                       while #uuids >= 5 do
                           local batch = {uuids[1], uuids[2], uuids[3], uuids[4], uuids[5]}
                           for i = 1, 5 do table.remove(uuids, 1) end
                           PetService.RF.goldify:InvokeServer(batch)
                           task.wait(0.3) 
                       end
                   end)
               end
               task.wait(3) 
           end
       end)
   end,
})


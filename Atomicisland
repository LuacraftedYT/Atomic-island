})

--- [[ MODULE 4: GRAVE ]] ---
GraveTab:CreateToggle({
   Name = "Auto-Dig Graves",
   CurrentValue = false,
   Callback = function(Value)
       _G.DigGrave = Value
       if Value and GraveService then
           task.spawn(function()
               while _G.DigGrave do
                   local folder = workspace.GameObjects:FindFirstChild("GraveDigging")
                   if folder then
                       for _, grave in ipairs(folder:GetChildren()) do
                           pcall(function() GraveService.RF.DigGrave:InvokeServer(grave) end)
                       end
                   end
                   task.wait(2)
               end
           end)
       end
   end,
})

--- [[ TABS ]] ---
local FarmTab = Window:CreateTab("🪓 Auto-Farm", 4483362458)
local GoldenTab = Window:CreateTab("✨ Auto-Golden", 4483362458)
local MerchantTab = Window:CreateTab("🛒 Auto-Merchant", 4483362458)

--- [[ MODULE 6: PRECISION GOLDEN ALCHEMIST ]] ---
local selectedPetToGold = "None"
local selectedArmToGold = "None"

-- 🦾 THE HARDCODED ARM LIST
local masterArmList = {
    "None",
    "MoltenIsland",
    "TornadoIsland",
    "BuffCoral",
    "SandstoneMuscle",
    "Floral",
    "MeltdownToad_Baby_Normal" -- Added here as well just in case
}

local PetDropdown = GoldenTab:CreateDropdown({
    Name = "Target Pet",
    Options = {"None", "MeltdownToad_Baby_Normal"},
    CurrentOption = {"None"},
    Callback = function(Option) selectedPetToGold = Option[1] end
})

GoldenTab:CreateButton({
   Name = "🔄 Refresh Pet Inventory",
   Callback = function()
       pcall(function()
           local ownedPets = PetService.RF.getOwned:InvokeServer()
           if type(ownedPets) == "table" then
               local uniqueNames = {"None", "MeltdownToad_Baby_Normal"}
               local nameSet = {}
               for _, petData in pairs(ownedPets) do
                   local petName = tostring(petData.Key or petData.Id or "Unknown")
                   if petName ~= "Unknown" and not nameSet[petName] then
                       nameSet[petName] = true table.insert(uniqueNames, petName)
                   end
               end
               PetDropdown:Refresh(uniqueNames, true)
           end
       end)
   end,
})

GoldenTab:CreateToggle({
   Name = "Auto-Craft Selected Pet",
   CurrentValue = false,
   Callback = function(Value)
       _G.AutoGoldenSelectedPet = Value
       task.spawn(function()
           while _G.AutoGoldenSelectedPet do
               if selectedPetToGold ~= "None" then
                   pcall(function()
                       local ownedPets = PetService.RF.getOwned:InvokeServer()
                       local uuids = {}
                       for uuid, petData in pairs(ownedPets) do
                           local pName = tostring(petData.Key or petData.Id)
                           if tostring(petData.Tier) == "Normal" and pName == selectedPetToGold then
                               table.insert(uuids, uuid)
                           end
                       end
                       while #uuids >= 5 do
                           local batch = {uuids[1], uuids[2], uuids[3], uuids[4], uuids[5]}
                           for i = 1, 5 do table.remove(uuids, 1) end
                           PetService.RF.goldify:InvokeServer(batch)
                           task.wait(0.3) 
                       end
                   end)
               end
               task.wait(3) 
           end
       end)
   end,
})

GoldenTab:CreateLabel("-----------------------------------")

local ArmDropdown = GoldenTab:CreateDropdown({
    Name = "Target Arm",
    Options = masterArmList,
    CurrentOption = {"None"},
    Callback = function(Option) selectedArmToGold = Option[1] end
})

GoldenTab:CreateButton({
   Name = "💉 Force-Inject Island Arms",
   Callback = function()
       ArmDropdown:Refresh(masterArmList, true)
       Rayfield:Notify({

--- [[ MODULE 1: AUTO-FARM ]] ---
local treeDatabase = {
    ["Palm Trees"] = {Vector3.new(-8595, 3, 8089), Vector3.new(-8610, 3, 8038), Vector3.new(-8620, 3, 8068), Vector3.new(-8643, 3, 8036), Vector3.new(-8661, 3, 8016)},
    ["Chaos Trees"] = {Vector3.new(-8780, 4, 8216), Vector3.new(-8814, 3, 8252)},
    ["Infested Trees"] = {Vector3.new(-7100, 3, 7892), Vector3.new(-7055, 3, 7870), Vector3.new(-7076, 4, 7831), Vector3.new(-7098, 3, 7843)}
}
local activeTreeLocations = treeDatabase["Palm Trees"]

FarmTab:CreateDropdown({
    Name = "Select Farming Route",
    Options = {"Palm Trees", "Chaos Trees", "Infested Trees"},
    CurrentOption = {"Palm Trees"},
    Callback = function(Option) activeTreeLocations = treeDatabase[Option[1]] end
})

FarmTab:CreateToggle({
   Name = "Start Coordinate Farm",
   CurrentValue = false,
   Callback = function(Value)
       _G.FarmActive = Value
       if Value and ChaosService then
           task.spawn(function()
               while _G.FarmActive do
                   for _, coord in ipairs(activeTreeLocations) do
                       if not _G.FarmActive then break end
                       pcall(function() ChaosService:Clicked() end)
                       task.wait(0.05)
                   end
               end
           end)
       end
   end,
})

--- [[ MODULE 2: AUTO-GOLDEN ]] ---
local selectedArm = "None"
local masterArmList = {"None", "MoltenIsland", "TornadoIsland", "BuffCoral", "SandstoneMuscle", "Floral", "MeltdownToad_Baby_Normal"}

local ArmDropdown = GoldenTab:CreateDropdown({
    Name = "Target Arm",
    Options = masterArmList,
    CurrentOption = {"None"},
    Callback = function(Option) selectedArm = Option[1] end
})

GoldenTab:CreateToggle({
   Name = "Auto-Craft Golden Arm",
   CurrentValue = false,
   Callback = function(Value)
       _G.AutoGoldArm = Value
       if Value and ArmsService then
           task.spawn(function()
               while _G.AutoGoldArm do
                   pcall(function()
                       local owned = ArmsService.RF.getOwned:InvokeServer(Player)
                       local uuids = {}
                       for id, data in pairs(owned) do
                           if tostring(data.ArmKey or data.Key) == selectedArm and tostring(data.Tier) == "Normal" then
                               table.insert(uuids, id)
                           end
                       end
                       if #uuids >= 5 then
                           ArmsService.RF.goldify:InvokeServer({uuids[1], uuids[2], uuids[3], uuids[4], uuids[5]})
                       end
                   end)
                   task.wait(2)
               end
           end)
       end
   end,
})

